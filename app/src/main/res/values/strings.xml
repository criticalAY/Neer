    <string name="plan_info_title">How this is calculated</string>
    <string name="plan_info_description">About the formula</string>
    <string name="plan_info_intro">Your daily goal is the larger of two numbers — a weight-based estimate (the clinical 30–40 ml/kg range, we use 35) and the Institute of Medicine\'s Adequate Intake floor for your gender. For ages 65+ we apply a 10 %% reduction to match the reduced thirst response documented in geriatric literature. Everything is rounded to the nearest 50 ml.</string>
    <string name="plan_info_step1_title">1. Weight-based estimate</string>
    <string name="plan_info_step1_body">%1$.1f kg × 35 ml/kg = %2$d ml</string>
    <string name="plan_info_step1_body_lb">%1$.1f lb (≈ %2$.1f kg) × 35 ml/kg = %3$d ml</string>
    <string name="plan_info_step2_title">2. IOM Adequate Intake floor</string>
    <string name="plan_info_step2_body">Adult %1$s: %2$d ml/day — the baseline healthy sedentary people in temperate climates meet through food and beverages.</string>
    <string name="plan_info_step3_title">3. Your daily goal</string>
    <string name="plan_info_step3_body">max(weight-based, IOM floor)%1$s rounded to 50 ml = %2$d ml.</string>
    <string name="plan_info_step3_elderly"> × 0.90 (age ≥ 65)</string>
    <string name="plan_info_schedule_title">About the reminder schedule</string>
    <string name="plan_info_schedule_body">Your goal is divided across your waking window (wake → sleep − 60 min), split into ≈ 90-minute slots. The morning slot is nudged +20 %% to counter overnight dehydration, the last slot tapered −15 %% so reminders don\'t wake you up.</string>
    <string name="plan_info_sources_title">Sources</string>
    <string name="plan_info_source_iom">IOM (2004) — Dietary Reference Intakes for Water, Potassium, Sodium, Chloride, Sulfate</string>
    <string name="plan_info_source_iom_url">https://www.nationalacademies.org/read/10925/chapter/6</string>
    <string name="plan_info_source_nap_news">National Academies press release on the DRI water report</string>
    <string name="plan_info_source_nap_news_url">https://www.nationalacademies.org/news/report-sets-dietary-intake-levels-for-water-salt-and-potassium-to-maintain-health-and-reduce-chronic-disease-risk</string>
    <string name="plan_info_source_mayo">Mayo Clinic — Water: How much should you drink every day?</string>
    <string name="plan_info_source_mayo_url">https://www.mayoclinic.org/healthy-lifestyle/nutrition-and-healthy-eating/in-depth/water/art-20044256</string>
    <string name="plan_info_source_pubmed">Total water intake by kilogram of body weight — Perrier et al., PubMed</string>
    <string name="plan_info_source_pubmed_url">https://pubmed.ncbi.nlm.nih.gov/34327801/</string>
    <string name="plan_info_source_acsm">ACSM — Exertional hydration guidance (+350 ml per 30 min of activity)</string>
    <string name="plan_info_source_acsm_url">https://journals.lww.com/acsm-msse/fulltext/2007/02000/exercise_and_fluid_replacement.22.aspx</string>
    <string name="plan_info_disclaimer">This is general guidance, not medical advice. Talk to your clinician if you have kidney, heart, or electrolyte conditions.</string>
